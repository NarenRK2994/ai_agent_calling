ERP_AGENT_APP_NAME=erp-ai-agent
ERP_AGENT_ENV=development
ERP_AGENT_DEBUG=false
DEBUG=false
TRACE_SQL=false
TRACE_PROMPTS=false
TRACE_STATE=false
TRACE_TIMING=false

ERP_AGENT_LOG_LEVEL=INFO
ERP_AGENT_LOG_FILE=

ERP_AGENT_METADATA_DIR=./metadata/agent_ready
ERP_AGENT_PROMPT_DIR=./prompts
ERP_AGENT_DATA_DIR=./data
ERP_AGENT_LOGS_DIR=./logs
ERP_AGENT_CACHE_TTL_SECONDS=300
ERP_AGENT_METRICS_ENABLED=true
ERP_AGENT_SQL_VALIDATION_RETRIES=2
ERP_AGENT_MAX_CONVERSATION_TURNS=10
ERP_AGENT_SQL_HISTORY_LIMIT=100
ERP_AGENT_RATE_LIMIT_REQUESTS=30
ERP_AGENT_RATE_LIMIT_WINDOW_SECONDS=60

ERP_AGENT_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
ERP_AGENT_LLM_DEVICE=auto
ERP_AGENT_LLM_CONTEXT_WINDOW=8192
ERP_AGENT_LLM_MAX_NEW_TOKENS=512
ERP_AGENT_LLM_TEMPERATURE=0.1

ERP_AGENT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
ERP_AGENT_EMBEDDING_DEVICE=cuda
ERP_AGENT_VECTOR_COLLECTION=erp_metadata
ERP_AGENT_VECTOR_TOP_K=5
ERP_AGENT_VECTOR_PERSIST_DIR=./data/vector_store

ORACLE_USERNAME=system
# ORACLE_USER=system
ORACLE_PASSWORD=oracle
ORACLE_HOST=localhost
ORACLE_PORT=1521
# ORACLE_SID=XE
ORACLE_SERVICE_NAME=XEPDB1
# ORACLE_DSN=localhost/XEPDB1
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=5
ORACLE_POOL_INCREMENT=1
ORACLE_TIMEOUT_SECONDS=30
ORACLE_STATEMENT_TIMEOUT_MS=30000
ORACLE_RETRY_ATTEMPTS=3
ORACLE_RETRY_BACKOFF_SECONDS=1.0
ORACLE_READ_ONLY=true
ORACLE_THICK_MODE=false
ORACLE_CLIENT_LIB_DIR=
ORACLE_CONFIG_DIR=
